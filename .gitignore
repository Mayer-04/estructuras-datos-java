# Archivos y carpetas de VS Code
# Ignora todo lo que esté dentro de .vscode excepto este archivo settings.json
.vscode/*   
!.vscode/settings.json

# Archivos compilados de Java
*.class

# Carpetas de compilación
bin/
build/
out/
target/

# Archivos de sistema
.DS_Store          # macOS
Thumbs.db          # Windows
desktop.ini        # Windows

# Archivos temporales
*.log
*.tmp
*.bak
*.swp
*~

# Archivos generados por herramientas
.mtj.tmp/          # Eclipse
.settings/         # Eclipse settings
.classpath         # Eclipse
.project           # Eclipse
.idea/             # IntelliJ IDEA
*.iml              # IntelliJ IDEA

# Dependencias descargadas
lib/

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*